# No API keys needed! We use your installed CLIs (Claude Code + Codex CLI).

# Optional: Override CLI paths (auto-detected by default)
# CLAUDE_PATH=/path/to/claude
# CODEX_PATH=/path/to/codex

# Safety: Default autonomy level (0-4)
# 0=ask everything, 1=suggest, 2=act+confirm, 3=act+report, 4=full auto
DEFAULT_AUTONOMY_LEVEL=1
