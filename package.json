{
  "name": "assistant",
  "version": "0.1.0",
  "description": "Autonomous personal AI assistant for macOS — security-first, cost-efficient, production-grade",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:int": "bun test tests/integration",
    "check": "bun run typecheck && bun run lint && bun test && bun run build"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
