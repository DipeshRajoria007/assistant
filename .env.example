# Required: At least one LLM provider
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Optional: Local model via Ollama (for private context triage)
# OLLAMA_BASE_URL=http://localhost:11434

# Safety: Default autonomy level (0-4)
# 0=ask everything, 1=suggest, 2=act+confirm, 3=act+report, 4=full auto
DEFAULT_AUTONOMY_LEVEL=1

# Memory: Embedding provider for vector search
# Options: anthropic, openai, ollama
EMBEDDING_PROVIDER=anthropic
